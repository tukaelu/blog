{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "rm -rf node_modules/.vite .astro .wrangler && astro dev",
    "build": "astro build && tsx scripts/generate-ogp.ts && pagefind --site dist/client && cp -r dist/client/pagefind public/pagefind && tsx scripts/update-csp.ts",
    "preview": "astro preview",
    "deploy": "pnpm build && wrangler deploy",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@astrojs/mdx": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.2",
    "wrangler": "^4.90.1"
  },
  "overrides": {
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@unocss/astro": "^66.6.8",
    "@unocss/preset-typography": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "budoux": "^0.8.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "node-html-parser": "^7.1.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "shiki": "^4.0.2",
    "tsx": "^4.21.0",
    "unocss": "^66.6.8"
  }
}
