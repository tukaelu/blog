---
interface Props {
  headings: { depth: number; slug: string; text: string }[]
  variant: 'mobile' | 'desktop'
}

const { headings, variant } = Astro.props
const filtered = headings.filter(h => (h.depth === 2 || h.depth === 3) && h.slug !== 'footnote-label')
---

{variant === 'mobile' && filtered.length > 0 && (
  <nav aria-label="目次">
    <details>
      <summary class="flex items-center justify-between px-4 py-3 cursor-pointer font-bold text-sm text-zinc-700 dark:text-zinc-200 select-none">
        <span>目次</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="toc-chevron w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </summary>
      <ol class="px-4 pb-4 mt-1 space-y-1.5">
        {filtered.map(h => (
          <li class:list={[h.depth === 3 && 'pl-4']}>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class="block text-sm text-zinc-600 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors py-0.5"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  </nav>
)}

{variant === 'desktop' && filtered.length > 0 && (
  <nav aria-label="目次">
    <p class="font-bold text-sm text-zinc-700 dark:text-zinc-200 mb-3">目次</p>
    <ol class="space-y-1.5">
      {filtered.map(h => (
        <li class:list={[h.depth === 3 && 'pl-4']}>
          <a
            href={`#${h.slug}`}
            data-toc-link={h.slug}
            class="block text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors py-0.5"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details[open] .toc-chevron {
    transform: rotate(180deg);
  }
  .toc-chevron {
    transition: transform 0.2s ease;
  }

  a[data-toc-link][data-active='true'] {
    font-weight: 600;
    color: #18181b; /* zinc-900 */
  }
  :global(.dark) a[data-toc-link][data-active='true'] {
    color: #fafafa; /* zinc-50 */
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
  if (links.length) {
    const slugs = [...new Set(Array.from(links).map(l => l.dataset.tocLink!))]
    const headingEls = slugs
      .map(s => document.getElementById(s))
      .filter((el): el is HTMLElement => el !== null)

    const visible = new Set<string>()

    const setActive = (slug: string) => {
      links.forEach(link => {
        link.dataset.active = link.dataset.tocLink === slug ? 'true' : 'false'
      })
    }

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.add(entry.target.id)
          else visible.delete(entry.target.id)
        }
        const active = slugs.find(s => visible.has(s))
        if (active) setActive(active)
      },
      { rootMargin: '-80px 0% -60% 0%', threshold: 0 }
    )

    headingEls.forEach(el => observer.observe(el))
  }
</script>
