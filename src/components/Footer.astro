---
const year = new Date().getFullYear()
---

<footer
  class="mt-4 flex-none border-t border-zinc-200 dark:border-zinc-600"
>
  <div class="mx-auto w-full max-w-4xl py-8 px-4 md:px-0 flex items-center justify-between">
    <p class="text-sm text-zinc-600 dark:text-zinc-300">
      &copy; {year} tuka
    </p>
    <a
      href="/rss.xml"
      aria-label="RSS"
      class="text-zinc-500 transition hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
        <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
      </svg>
    </a>
  </div>
</footer>
