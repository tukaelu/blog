---
interface Props {
  href?: string
  class?: string
  [key: string]: unknown
}

const { href, ...rest } = Astro.props
const isExternal = href?.startsWith('http')
const externalAttrs = isExternal
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {}
---

<a href={href} {...rest} {...externalAttrs}>
  <slot />
</a>
