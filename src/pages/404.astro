---
import BaseLayout from '@layouts/BaseLayout.astro'
import { SITE_TITLE } from '@lib/constants'
---

<BaseLayout title={`404 Not Found | ${SITE_TITLE}`} description="Page not found">
  <div class="flex flex-col items-center justify-center py-20">
    <h1 class="text-4xl font-bold dark:text-white">404</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-400">Page not found</p>
    <a href="/" class="mt-6 text-odwr-300 hover:underline">Back to top</a>
  </div>
</BaseLayout>
