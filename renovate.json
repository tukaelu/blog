{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":timezone(Asia/Tokyo)"],
  "schedule": [
    "after 6pm every weekday",
    "every weekend",
    "before 8am every weekday"
  ],
  "labels": ["renovate"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "automerge": true
  },
  "npm": {
    "rangeStrategy": "bump"
  },
  "vulnerabilityAlerts": {
    "labels": ["security"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["renovate", "major"]
    },
    {
      "matchPackageNames": ["@types/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "groupName": "astro",
      "matchPackageNames": ["astro", "@astrojs/**"]
    },
    {
      "groupName": "unocss",
      "matchPackageNames": ["unocss", "@unocss/**"]
    },
    {
      "groupName": "date-fns",
      "matchPackageNames": ["date-fns", "date-fns-tz"]
    },
    {
      "groupName": "syntax highlighting",
      "matchPackageNames": ["shiki", "rehype-pretty-code"]
    },
    {
      "groupName": "linters",
      "matchPackageNames": ["/eslint/", "prettier", "stylelint"]
    }
  ]
}
